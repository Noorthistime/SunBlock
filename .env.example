# SunBlock - Environment Variables Template
# No API keys are required to run the weather dashboard out-of-the-box (uses Open-Meteo Geocoding & Weather APIs).

# Optional: Set the application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: For future extensions to other weather providers
# OPENWEATHER_MAP_API_KEY=your_openweather_key_here
# WEATHERAPI_API_KEY=your_weatherapi_key_here
